{
  // MA Golden Cross Backtest - Project-level oh-my-openagent config
  // Models inherit from global ~/.config/opencode/oh-my-openagent.json (MiniMax)

  // Enable task system for agent coordination tracking
  "experimental": {
    "task_system": true
  },

  // Playwright skill enabled for E2E verification
  "disabled_skills": [],

  // All hooks enabled
  "disabled_hooks": [],

  // Background agent concurrency (3 parallel to avoid API rate limits on MiniMax)
  "background_agent": {
    "max_concurrent_per_model": 3
  }
}
